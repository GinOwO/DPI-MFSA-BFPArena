# ZDPI instance configuration copy to .env and fill in values.
# .env is gitignored; this file is the committed template.
#
# Get MACs with: ip link show ens5 | grep 'link/ether' | awk '{print $2}'
# Get private IPs with: ip -o addr show ens5 | grep -oP '172\.\S+' | cut -d/ -f1

RECV_PUBLIC=1.2.3.4
RECV_PRIVATE=172.31.x.x
RECV_MAC=00:00:00:00:00:00

SEND_PUBLIC=1.2.3.5
SEND_PRIVATE=172.31.x.x
SEND_MAC=00:00:00:00:00:00
